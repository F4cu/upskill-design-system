# Local Airtable credentials for token sync / governance scripts.
# Copy to .env and fill in. .env is gitignored — never commit real keys.
# An explicit `export VAR=...` in your shell overrides anything set here.

# Personal access token. Needs scopes: data.records:read, data.records:write
# (governance:setup also needs schema.bases:write). Add the base below to the
# token's access list at https://airtable.com/create/tokens
AIRTABLE_API_KEY=

# Optional — defaults to appBfY2arkReKQNit if unset.
# AIRTABLE_BASE_ID=appBfY2arkReKQNit
