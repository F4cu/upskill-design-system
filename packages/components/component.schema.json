{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "upskill-design-system/component.schema.json",
  "title": "Component Metadata",
  "type": "object",
  "required": [
    "component",
    "usage",
    "variants",
    "states",
    "tokens",
    "accessibility",
    "relationships"
  ],
  "properties": {
    "component": {
      "type": "object",
      "required": ["name", "category", "type", "status", "description"],
      "properties": {
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["atom", "molecule", "organism", "layout"]
        },
        "type": {
          "type": "string",
          "enum": ["interactive", "display", "container", "input"]
        },
        "status": {
          "type": "string",
          "enum": ["beta", "ready", "deprecated"]
        },
        "description": { "type": "string" },
        "figmaNodeId": { "type": "string" }
      },
      "additionalProperties": false
    },

    "usage": {
      "type": "object",
      "required": ["keywords", "when", "antiPatterns"],
      "properties": {
        "keywords": {
          "description": "Terms an agent uses to match intent to this component during layout generation or selection.",
          "type": "array",
          "items": { "type": "string" }
        },
        "when": {
          "description": "Scenarios where this component is the right choice.",
          "type": "array",
          "items": { "type": "string" }
        },
        "antiPatterns": {
          "description": "Explicit misuses. Anti-patterns are load-bearing — they prevent the most common agent errors.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scenario", "reason", "alternative"],
            "properties": {
              "scenario": { "type": "string" },
              "reason": { "type": "string" },
              "alternative": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "variants": {
      "description": "Named variant axes. Each key is an independent axis (e.g. variant, size, shape). A single-axis component declares one axis named `variant`; a component with no visual variation declares `variant` with a single `default` option.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["options", "default", "purpose"],
        "properties": {
          "options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "default": {
            "type": ["string", "null"],
            "description": "Default option for this axis, or null when the axis is off by default (e.g. an icon-only shape applied only when set)."
          },
          "purpose": {
            "description": "Per-option selection guidance — when to choose each option on this axis over the others.",
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },

    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state", "description"],
        "properties": {
          "state": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "tokens": {
      "type": "object",
      "properties": {
        "color": { "type": "array", "items": { "type": "string" } },
        "spacing": { "type": "array", "items": { "type": "string" } },
        "typography": { "type": "array", "items": { "type": "string" } },
        "borderRadius": { "type": "array", "items": { "type": "string" } },
        "other": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "accessibility": {
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "notes": {
          "description": "Accessibility guidance specific to this component that the role/aria/keyboard fields don't capture.",
          "type": "string"
        },
        "ariaAttributes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "keyboardInteractions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "action"],
            "properties": {
              "key": { "type": "string" },
              "action": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "relationships": {
      "type": "object",
      "properties": {
        "composedOf": {
          "description": "Library components used internally to build this component.",
          "type": "array",
          "items": { "type": "string" }
        },
        "accepts": {
          "description": "Component names valid as direct children in this component's content slot. Empty array means leaf node. [\"*\"] means any library component is valid.",
          "type": "array",
          "items": { "type": "string" }
        },
        "containedBy": {
          "description": "Component names that are valid direct parents of this component.",
          "type": "array",
          "items": { "type": "string" }
        },
        "neverPairWith": {
          "description": "Components that must not appear as siblings or in the same composition as this one.",
          "type": "array",
          "items": { "type": "string" }
        },
        "compositionPatterns": {
          "description": "Named, tested patterns that use this component. Concrete starting points for layout generation.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description", "tree"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "tree": {
                "type": "string",
                "description": "Component tree as a readable expression, e.g. 'Card > Stack > [Heading, Text, Button(primary)]'"
              }
            },
            "additionalProperties": false
          }
        },
        "layoutBehavior": {
          "description": "How this component behaves inside a layout container. Used by the layout generation moment.",
          "type": "object",
          "properties": {
            "widthBehavior": {
              "type": "string",
              "enum": ["fill", "hug", "fixed"],
              "description": "fill = stretches to parent width; hug = sizes to content; fixed = component sets its own width"
            },
            "displayType": {
              "type": "string",
              "enum": ["block", "inline", "flex-column", "flex-row", "grid"]
            },
            "canNest": {
              "type": "boolean",
              "description": "Whether this component can be meaningfully nested inside another instance of itself"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
