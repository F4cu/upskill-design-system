{
  "name": "upskill-design-system",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "ajv": "^8.18.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "storybook": "^10",
    "typescript-eslint": "^8.61.1"
  },
  "scripts": {
    "build": "npm run tokens:build && npm run build -w @upskill/components && npm run build -w @upskill/showcase",
    "tokens:build": "npm run build:tokens -w @upskill/tokens",
    "typecheck": "npm run typecheck -w @upskill/components",
    "storybook": "npm run storybook -w @upskill/components",
    "airtable:push:primitives": "node scripts/airtable-sync.js push:primitives",
    "airtable:push:semantic": "node scripts/airtable-sync.js push:semantic",
    "airtable:push:device": "node scripts/airtable-sync.js push:device",
    "airtable:push:components": "node scripts/airtable-sync.js push:components",
    "airtable:sync:components": "npm run sense && npm run airtable:push:components",
    "airtable:sync:all": "npm run airtable:push:primitives && npm run airtable:push:semantic && npm run airtable:push:device && npm run airtable:sync:components",
    "airtable:setup": "node scripts/airtable-setup-governance.js",
    "airtable:pull:governance": "node scripts/airtable-pull.js && node scripts/token-deprecation-mirror.js",
    "tokens:deprecations": "node scripts/token-deprecation-mirror.js",
    "tokens:deprecations:check": "node scripts/token-deprecation-mirror.js --check",
    "pipeline:status": "node scripts/pipeline-status.js",
    "pipeline-dashboard": "npm run dev -w @upskill/showcase -- --port 5176",
    "tokens:usage": "node scripts/token-usage.js",
    "tokens:contrast-check": "node scripts/token-contrast-check.js",
    "sense": "node scripts/sense.js",
    "status": "node scripts/status.js",
    "status:board": "node scripts/status.js board",
    "status:component": "node scripts/status.js component",
    "patterns:generate": "node scripts/generate-pattern-schema.js",
    "harness:run": "node scripts/pattern-accuracy-harness/run.js",
    "harness:score": "node scripts/pattern-accuracy-harness/score.js",
    "sense:component": "node scripts/sense-component.js",
    "handoff:tidy": "node scripts/handoff-tidy.js",
    "docs:check": "node scripts/docs-check.js",
    "claudemd:check": "node scripts/claude-md-check.js",
    "lint": "eslint packages/components/src",
    "metadata:validate": "node scripts/validate-metadata.js",
    "layout:validate": "node scripts/validate-layout.js",
    "screenshot:check": "node scripts/screenshot.js check",
    "screenshot:approve": "node scripts/screenshot.js approve",
    "a11y:coverage": "node scripts/a11y-coverage.js",
    "a11y:test": "npm run test:a11y -w @upskill/components",
    "a11y:stories": "npm run test:a11y:stories -w @upskill/components"
  }
}
