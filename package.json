{
  "name": "upskill-design-system",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "ajv": "^8.18.0",
    "storybook": "^10"
  },
  "scripts": {
    "build": "npm run build:tokens && npm run build -w @upskill/components",
    "build:tokens": "npm run build:tokens -w @upskill/tokens",
    "typecheck": "npm run typecheck -w @upskill/components",
    "storybook": "npm run storybook -w @upskill/components",
    "build:storybook": "npm run build:storybook -w @upskill/components",
    "sync:tokens:push": "node scripts/airtable-sync.js push:primitives",
    "sync:semantic:push": "node scripts/airtable-sync.js push:semantic",
    "sync:device:push": "node scripts/airtable-sync.js push:device",
    "sync:all:push": "npm run sync:tokens:push && npm run sync:semantic:push && npm run sync:device:push",
    "governance:setup": "node scripts/airtable-setup-governance.js",
    "governance:pull": "node scripts/airtable-pull.js",
    "token-usage": "node scripts/token-usage.js",
    "sense": "node scripts/sense.js",
    "sense:component": "node scripts/sense-component.js",
    "validate:metadata": "node scripts/validate-metadata.js"
  }
}
